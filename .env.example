# ─── App ──────────────────────────────────────────────────────────────
APP_NAME="Robot Camera Analytics API"
APP_VERSION="1.0.0"
DEBUG=false

# ─── Azure SQL ────────────────────────────────────────────────────────
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=your-database
AZURE_SQL_USERNAME=your-username
AZURE_SQL_PASSWORD=your-password
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# ─── Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# ─── Qdrant ───────────────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_INCIDENTS=historical_incidents
QDRANT_COLLECTION_STANDARDS=singapore_standards
QDRANT_COLLECTION_MANUALS=oem_manuals

# ─── Image Storage ────────────────────────────────────────────────────
IMAGE_UPLOAD_DIR=./app/images
MAX_IMAGE_SIZE_MB=10

# ─── Business Thresholds ──────────────────────────────────────────────
HIGH_SEVERITY_COST_THRESHOLD=5000.0
CRITICAL_FAILURE_PROBABILITY_THRESHOLD=0.30
